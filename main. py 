import logging
import time
from aiogram import Bot, Dispatcher, types
from aiogram.utils import executor
from aiogram.types import InlineKeyboardMarkup, InlineKeyboardButton

# Render loglarida jarayonni ko'rish uchun
logging.basicConfig(level=logging.INFO)

# TOKENNI TO'G'RIDAN-TO'G'RI SHU YERGA YOZDIK
TOKEN = "8637820333:AAFkZ6NO2rz-uFOFGde2KPim33k25RkFzYY"
ADMIN_ID = 5710284858  # O'zingizning ID raqamingiz

bot = Bot(token=TOKEN)
dp = Dispatcher(bot)

users = {}
FREE_LIMIT = 5

# ----------- START -----------
@dp.message_handler(commands=['start'])
async def start(msg: types.Message):
    user_id = msg.from_user.id
    if user_id not in users:
        users[user_id] = {
            "balance": 8000000,
            "used": 0,
            "date": time.strftime("%Y-%m-%d"),
            "premium_until": 0
        }
    await msg.answer("🤖 Xush kelibsiz!\n\n🎁 BONUS: 8,000,000\n💰 /balance\n🤖 /create\n💎 /premium")

# ----------- BALANCE -----------
@dp.message_handler(commands=['balance'])
async def balance(msg: types.Message):
    u = users.get(msg.from_user.id)
    if not u:
        return await msg.answer("Avval /start bosing")
    
    premium_status = "✅ Bor" if time.time() < u["premium_until"] else "❌ Yo'q"
    await msg.answer(f"💰 Balans: {u['balance']}\n💎 Premium: {premium_status}")

# ----------- CREATE -----------
@dp.message_handler(commands=['create'])
async def create(msg: types.Message):
    user_id = msg.from_user.id
    u = users.get(user_id)
    if not u:
        return await msg.answer("Avval /start bosing")

    if u["balance"] < 100000:
        return await msg.answer("❌ Pul yetarli emas")

    # Limit tekshirish
    today = time.strftime("%Y-%m-%d")
    if u["date"] != today:
        u["date"] = today
        u["used"] = 0

    if time.time() < u["premium_until"] or u["used"] < FREE_LIMIT:
        u["used"] += 1
        u["balance"] -= 100000
        await msg.answer("🤖 Bot muvaffaqiyatli yaratildi!")
    else:
        await msg.answer("❌ Kunlik limit tugadi. Premium oling 💎")

# ----------- PREMIUM -----------
@dp.message_handler(commands=['premium'])
async def premium(msg: types.Message):
    kb = InlineKeyboardMarkup()
    kb.add(InlineKeyboardButton("💎 30 kun - 1100 UZS", callback_data="buy_premium"))
    await msg.answer("💎 Premium olish uchun quyidagi tugmani bosing:", reply_markup=kb)

@dp.callback_query_handler(lambda c: c.data == "buy_premium")
async def buy(call: types.CallbackQuery):
    await bot.send_message(ADMIN_ID, f"💰 Premium so'rov!\nUser ID: {call.from_user.id}")
    await call.message.answer("💳 To'lov ma'lumotlarini olish uchun admin bilan bog'laning.")

if __name__ == "__main__":
    executor.start_polling(dp, skip_updates=True)
